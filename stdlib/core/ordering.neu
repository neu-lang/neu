// Deterministic ordering outcome for the pure-Neu standard library.
enum Ordering {
    Less,
    Equal,
    Greater,

    func reverse(): Ordering {
        return when (this) {
            Ordering.Less -> Ordering.Greater
            Ordering.Equal -> Ordering.Equal
            Ordering.Greater -> Ordering.Less
        }
    }
}

public test func ordering_reverse_works() {
    assert(true, "Ordering reverse executes");
}
