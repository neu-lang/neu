// Planned Neu class surface. Constructors and object lowering are not yet in
// the runnable current-example set.
class Point(val x: Int, var y: Int) {
    func value(): Int {
        return x;
    }
}

interface Describable {
    func describe(): Int;
}

class ColoredPoint: Point(), Describable {
    override func value(): Int {
        return x;
    }

    func describe(): Int {
        return value();
    }
}
