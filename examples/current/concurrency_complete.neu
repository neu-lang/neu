suspend func main(): Int {
    var total: Int = 0;
    scope {
        scope {
            val first = spawn { -> 3 };
            val second = spawn { -> 4 };
            total = await(first) + await(second);
        }

        val queue = channel<Int>(1);
        send(queue, total);
        val result = receive(queue);
        val cancelled = spawn { -> 99 };
        cancelled.cancel();
        return total;
    }
    return total;
}
