package examples.current

func choose(value: Int): Int {
    return 3;
}

func choose(value: Bool): Int {
    return 4;
}

class Calculator {
    func scale(value: Int): Int {
        return value + 1;
    }

    func scale(value: Bool): Int {
        return 6;
    }
}

public func main(): Int {
    val calculator: Calculator = new Calculator();
    return choose(true) + calculator.scale(true);
}
